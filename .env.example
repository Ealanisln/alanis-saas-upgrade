# =============================================================================
# ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local or .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Base URL for your external API
NEXT_PUBLIC_API_BASE_URL=https://api.alanis.dev

# -----------------------------------------------------------------------------
# Sanity CMS Configuration
# -----------------------------------------------------------------------------
# Your Sanity project ID (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Sanity dataset name (usually 'production' or 'development')
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (format: YYYY-MM-DD)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-14

# Sanity API token for authenticated requests (server-side only)
# Get this from https://sanity.io/manage
SANITY_API_TOKEN=your_sanity_api_token_here

# Sanity webhook secret for on-demand revalidation
# Generate a random string and use the same value in your Sanity webhook
# Generate with: openssl rand -base64 32
SANITY_REVALIDATE_SECRET=your_sanity_revalidate_secret_here

# -----------------------------------------------------------------------------
# Site Configuration & SEO
# -----------------------------------------------------------------------------
# Your site's public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://alanis.dev

# Contact email for SEO structured data
NEXT_PUBLIC_CONTACT_EMAIL=contact@alanis.dev

# Social Media Links (for SEO structured data)
NEXT_PUBLIC_GITHUB_URL=https://github.com/alanisdev
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/alanisdev
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/alanisdev

# -----------------------------------------------------------------------------
# Contact Form (Cloudflare Turnstile + Resend)
# -----------------------------------------------------------------------------
# Turnstile anti-bot keys — https://dash.cloudflare.com/?to=/:account/turnstile
# If unset, the widget is hidden and the form submits without verification.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Resend API key for email delivery — https://resend.com/api-keys
# If unset, contact form submissions fail with a user-facing error.
RESEND_API_KEY=your_resend_api_key_here

# Sender / recipient for contact form notifications (defaults shown)
# EMAIL_FROM=Alanis Dev <noreply@alanis.dev>
# EMAIL_TO=emmanuel@alanis.dev

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------
# Vercel Analytics ID
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id_here

# Custom analytics endpoint (if using self-hosted)
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://analytics.alanis.dev/script.js
# NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=ff7f7fca-11fa-497f-814a-ee473d935868

# -----------------------------------------------------------------------------
# Authentication (if implemented)
# -----------------------------------------------------------------------------
# NextAuth secret (generate with: openssl rand -base64 32)
# NEXTAUTH_SECRET=your_nextauth_secret_here
# NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting & Security (when implemented)
# -----------------------------------------------------------------------------
# Redis/Upstash URL for rate limiting
# UPSTASH_REDIS_REST_URL=your_upstash_url_here
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Set to 'development' or 'production'
NODE_ENV=development

# Enable detailed error messages in development
# NEXT_PUBLIC_ENABLE_ERROR_DETAILS=true

# -----------------------------------------------------------------------------
# Invoice Ninja Integration (if used)
# -----------------------------------------------------------------------------
# Invoice Ninja API URL
# INVOICE_NINJA_URL=https://your-invoice-ninja-instance.com
# INVOICE_NINJA_TOKEN=your_invoice_ninja_token

# -----------------------------------------------------------------------------
# Optional: Database (if needed in future)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# -----------------------------------------------------------------------------
# Optional: OAuth Providers (if needed in future)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# NOTES:
# =============================================================================
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. Variables without NEXT_PUBLIC_ are server-side only
# 3. Never commit your actual .env file to version control
# 4. Add .env.local to your .gitignore file
# 5. For production, use Vercel Environment Variables or your hosting provider's solution
# =============================================================================
